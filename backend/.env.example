# Upstage — used for BOTH document parsing/OCR AND all LLM reasoning
# (compliance loop, chat, summaries). Get a key at https://console.upstage.ai
# Free tier: $10 credits on signup.
UPSTAGE_API_KEY=up_...

# Optional: Slack incoming webhook for document summaries
SLACK_WEBHOOK_URL=

# Optional overrides
# Upstage Solar reasoning model. "solar-pro3" is the flagship; use
# "solar-pro2" for cheaper/faster non-reasoning calls.
UPSTAGE_MODEL=solar-pro3
# Reasoning depth for solar-pro3: "low" | "medium" | "high".
UPSTAGE_REASONING_EFFORT=medium
# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
# DocZilla backend port (avoid 8000 — often used by other local apps).
PORT=8001
